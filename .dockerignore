###############################################################################
# Production Docker context hygiene
###############################################################################

# VCS and local agents
.git/
.github/
.agent/
.claude/
.cursor/
.windsurf/
.idea/
.vscode/

# Secrets and local environment
.env
.env.*
!.env.example
!.env.sample
**/.env
**/.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_ed25519

# Python environments, caches, and compiled artifacts
.conda/
.venv/
venv/
env/
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.pyright/

# Node dependencies and package-manager caches
**/node_modules/
**/.npm/
**/.yarn/
**/.pnpm-store/

# Runtime data and local state
logs/**
tmp/**
usr/**
!usr/
!usr/plugins/
!usr/plugins/avender/
!usr/plugins/avender/**
usr/workdir/**
usr/**/*.db
usr/**/*.sqlite
usr/**/*.sqlite3
memory/**
instruments/**
knowledge/custom/**
*.db
*.sqlite
*.sqlite3

# Django generated static output. SysAdmin runs collectstatic at startup.
admin/staticfiles/**

# Test, coverage, and browser artifacts
tests/
test-results/
playwright-report/
blob-report/
playwright/.cache/
*.spec.js.snap
htmlcov/
.coverage
coverage.xml
/*.test.py

# OS/editor junk
**/.DS_Store
**/Thumbs.db
*~
*.bak
*.backup
*.old
*.orig

# Keep intentional empty directory markers when their parent is included.
!**/.gitkeep
