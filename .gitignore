# Ignore common unwanted files globally
**/.DS_Store
**/Thumbs.db
**/.env
**/.env.*
!.env.example
!.env.sample
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
**/.conda/
**/node_modules/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.pyright/

# Ignore IDE files
.cursor/
.windsurf/
.idea/
.vscode/

# ignore test files in root dir
/*.test.py

# Ignore all contents of the virtual environment directory
.venv/
venv/
env/

# obsolete folders
/memory/
/knowledge/custom/
/instruments/

# Handle logs directory
logs/**
!logs/**/

# Handle tmp and usr directory
tmp/**
!tmp/**/

# hack to keep .gitkeep but ignore nested repos
# Ignore everything under usr
usr/**
# Ignore nested repos
/usr/**/.git
# Allow git to traverse directories
!usr/**/
# Re-ignore everything again
usr/**/*
# But allow .gitkeep files
!usr/**/.gitkeep
!usr/plugins/
!usr/plugins/avender/
!usr/plugins/avender/helpers/
!usr/plugins/avender/helpers/auth.py
!usr/plugins/avender/helpers/config.py
!usr/plugins/avender/webui/
!usr/plugins/avender/webui/onboarding.css
!usr/plugins/avender/webui/onboarding_lit.js
!usr/plugins/avender/webui/onboarding_actions.js
!usr/plugins/avender/webui/onboarding_views.js


# Global rule to include .gitkeep files anywhere
!**/.gitkeep

# for browser-use
agent_history.gif

.agent/**
.claude/**

# Ignore databases and runtime state
*.db
*.sqlite3
*.sqlite
admin/db.sqlite3
usr/workdir/
usr/**/*.db
usr/**/*.sqlite
usr/**/*.sqlite3

# Django generated assets
admin/staticfiles/

# Secrets and private keys
deployments/avender/secrets/
deployments/avender/*.secret
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_ed25519


# Playwright artifacts
test-results/
playwright-report/
blob-report/
playwright/.cache/
*.spec.js.snap

# Build and coverage artifacts
dist/
build/
htmlcov/
.coverage
coverage.xml
