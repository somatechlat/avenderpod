# ¡A VENDER! Environment Variables — EXAMPLE TEMPLATE
# ============================================================================
# Copy this file to .env and customize as needed.
# NEVER put secrets in this file. All secrets must come from Vault.
#
# Setup:
#   1. Copy:  cp .env.example .env
#   2. Seed Vault:  python vault_bootstrap.py
#   3. Materialize:  python vault_materialize_secrets.py
#   4. Start:  docker compose up -d
# ============================================================================

# Agent Zero — Cognitive Engine
LLM_PROVIDER=openrouter
CHAT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# PostgreSQL (password comes from secrets/postgres_password)
POSTGRES_DB=avender_db
POSTGRES_USER=avender_user

# Django
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@avender.local

# Vultr Infrastructure
VULTR_REGION=mia
VULTR_PLAN=vc2-2c-4gb
VULTR_OS_ID=2136
# VULTR_VPC_ID=
# VULTR_FIREWALL_GROUP_ID=
# CLUSTER_VPC_IP=

# Vault (defaults work for local Docker Compose deployment)
# VAULT_ADDR=http://vault:8200
# VAULT_KV_MOUNT=secret
# VAULT_NAMESPACE=
# VAULT_TIMEOUT_SECONDS=10

# Secrets directory (default: ./secrets)
# AVENDER_SECRETS_DIR=./secrets
