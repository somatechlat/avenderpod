# ============================================================================
# ¡A VENDER! — Non-secret deployment configuration
# ============================================================================
# Do not put passwords, API keys, tokens, or Django secret keys in this file.
# Materialize every secret from Vault into ${AVENDER_SECRETS_DIR} before starting
# Docker Compose. Required files are documented below.

POSTGRES_DB=avender_db
POSTGRES_USER=avender_user

DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@avender.local

VULTR_REGION=mia
VULTR_PLAN=vc2-2c-4gb
VULTR_OS_ID=2136
VULTR_VPC_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VULTR_FIREWALL_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLUSTER_VPC_IP=10.240.1.10

VAULT_ADDR=https://vault.example.com
VAULT_KV_MOUNT=secret
VAULT_NAMESPACE=
VAULT_TIMEOUT_SECONDS=10

A0_IMAGE=agent0ai/agent-zero-tenant:latest
DEV_TENANT_ID=00000000-0000-0000-0000-000000000000

# Local path populated by Vault Agent or another approved Vault materializer.
AVENDER_SECRETS_DIR=./secrets

# The included helper reads these Vault KV v2 paths:
# - secret/data/avender/sysadmin
# - secret/data/avender/dev-agent
# Run from deployments/avender with:
#   VAULT_TOKEN_FILE=/secure/path/vault_token python3 vault_materialize_secrets.py

# Required secret files under ${AVENDER_SECRETS_DIR}:
# - postgres_password
# - django_secret_key
# - django_superuser_password
# - sysadmin_api_key
# - vultr_api_key
# - vault_token
# - avender_setup_token
